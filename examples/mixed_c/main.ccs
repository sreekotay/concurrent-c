#include <ccc/std/prelude.cch>

#include "helper.h"

int main(void) {
    CCArena arena_storage = @create(kilobytes(4)) @destroy;
    if (!arena_storage.base) return 1;
    CCArena* arena = &arena_storage;
    {
        CCString s = cc_string_new();
        int v = helper_add(2, 5);
        s.append("mixed_c helper_add(2,5)=", arena);
        cc_string_push_int(&s, v, arena);
        s.append("\n", arena);
        cc_std_out.write(s);
    }
    return 0;
}


