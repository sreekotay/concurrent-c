#include <ccc/std/prelude.cch>

#include "helper.h"

int main(void) {
    CCArena arena_storage = @create(kilobytes(4)) @destroy;
    if (!arena_storage.base) return 1;
    CCArena* arena = &arena_storage;
    {
        CCString s = CCString_new(arena);
        int v = helper_add(2, 5);
        s.append("mixed_c helper_add(2,5)=");
        CCString_push_int(&s, v);
        s.append("\n");
        cc_std_out.write(s);
    }
    return 0;
}


