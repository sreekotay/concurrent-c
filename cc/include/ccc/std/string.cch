    CCString s = int8_t_to_str(v, arena);
    return cc__string_persist_slice(arena, &s);
}

static inline CCSlice cc__string_slot_from_uint8_t(uint8_t v, CCArena *arena) {
    CCString s = uint8_t_to_str(v, arena);
    return cc__string_persist_slice(arena, &s);
