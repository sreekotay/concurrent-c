/* Test: capture-all by reference [&] is banned */
#include <ccc/cc_nursery.cch>

int main(void) {
    int x = 0;
    
    {
        CCNursery* __cc_nursery31 = @create(NULL) @destroy;
        if (!__cc_nursery31) abort();

        /* ERROR: capture-all [&] is not allowed */
        __cc_nursery31->spawn(() => [&] {
            x++;
        });
    
    }
    
    return 0;
}
