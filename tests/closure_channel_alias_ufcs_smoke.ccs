#include <assert.h>
#include <stdio.h>

int main(void) {
    int[~8 >] tx_h;
    int[~8 <] rx_h;
    CCChan* ch = cc_channel_pair(&tx_h, &rx_h);
    CCChanTx tx = tx_h;
    CCChanRx rx = rx_h;
    int got = 0;
    int* got_ptr = &got;

    assert(ch != NULL);

    {
        CCNursery* __cc_nursery38 = @create(NULL) @destroy;
        if (!__cc_nursery38) abort();
        (void)__cc_nursery38->close_on(tx_h);

        __cc_nursery38->spawn(() => [tx] {
            tx.send(1);
        });
        __cc_nursery38->spawn(() => [rx, got_ptr] {
            int v = 0;
            rx.recv(&v);
            *got_ptr = v;
        });
    
    }

    assert(got == 1);
    ch.free();

    printf("closure_channel_alias_ufcs_smoke: PASS\n");
    return 0;
