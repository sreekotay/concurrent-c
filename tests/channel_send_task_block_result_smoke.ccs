#include <ccc/std/prelude.cch>
#include <stdio.h>

static int compute_result(int value) {
    if (value < 0) return -1;
    return value * 3;
}

int main(void) {
    int[~4 >] tx;
    int[~4 ordered <] rx;
    CCChan* ch = cc_channel_pair(&tx, &rx);
    int ok = 1;

    {
        CCNursery* __cc_nursery21 = @create(NULL) @destroy;
        if (!__cc_nursery21) abort();

        {
            CCNursery* __cc_nursery22 = @create(NULL) @destroy;
            if (!__cc_nursery22) abort();
            (void)__cc_nursery22->close_on(tx);

            __cc_nursery22->spawn(() => [tx] {
                cc_channel_send_task(tx, () => {
                    int res = compute_result(2);
                    res;
                });
                cc_channel_send_task(tx, () => {
                    int res = compute_result(-1);
                    res;
                });
            });
        
        }

        int result = 0;
        if (!cc_io_avail(rx.recv(&result)) || result != 6) {
            ok = 0;
        }
        if (!cc_io_avail(rx.recv(&result)) || result != -1) {
            ok = 0;
        }
        if (cc_io_avail(rx.recv(&result))) {
            ok = 0;
        }
    
    }

    cc_chan_free(ch);
    if (!ok) {
        printf("channel_send_task_block_result_smoke: FAIL\n");
        return 1;
    }
    printf("channel_send_task_block_result_smoke: PASS\n");
    return 0;
}
