// Smoke test for ordered channels
//
// Covers:
//   1. Legacy path: CCTask channel + ordered_recv helper (backward compat)
//   2. New path: T[~N ordered >/<] + chan_recv auto-await, statement-form channel_pair
//   3. New path: T[~N ordered >/<] + chan_recv auto-await, expression-form channel_pair
//
#include <ccc/std/prelude.cch>
#include <stdio.h>

intptr_t compute(intptr_t x) {
    return x * 2;
}

int !>(CCIoError) compute_result(int x) {
    if (x < 0) return cc_err(cc_io_error(CC_IO_OTHER));
    return cc_ok(x * 3);
}

/* -----------------------------------------------------------------------
 * 1. Legacy: explicit CCTask channel + ordered_recv
 * ----------------------------------------------------------------------- */
static int test_legacy_ordered_recv(void) {
    CCTask[~8 >] tx;
    CCTask[~8 <] rx;
    cc_channel_pair(&tx, &rx);

    intptr_t values[] = {10, 200, 30, 400, 50};
    int n = sizeof(values) / sizeof(values[0]);

    {
        CCNursery* __cc_nursery73 = @create(NULL) @destroy;
        if (!__cc_nursery73) abort();
        (void)__cc_nursery73->close_on(tx);

        for (int i = 0; i < n; i++) {
            intptr_t v = values[i];
            cc_channel_send_task(tx, () => [v] compute(v));
        }
    
    }

    void* result;
    int idx = 0;
    while (ordered_recv(rx, &result) == 1 && idx < n) {
        intptr_t got = (intptr_t)result;
        intptr_t expected = values[idx] * 2;
        if (got != expected) {
            printf("FAIL legacy ordered_recv: pos %d expected %lld got %lld\n",
                   idx, (long long)expected, (long long)got);
            chan_free(rx);
            return 0;
        }
        idx++;
    }
    chan_free(rx);
    if (idx != n) { printf("FAIL legacy: got %d values, expected %d\n", idx, n); return 0; }
    return 1;
}

/* -----------------------------------------------------------------------
 * 2. New: typed ordered channel, statement-form channel_pair,
 *         chan_recv auto-awaits and delivers typed result
 * ----------------------------------------------------------------------- */
static int test_typed_ordered_stmt_form(void) {
    intptr_t[~8 >] tx;
    intptr_t[~8 ordered <] rx;
    cc_channel_pair(&tx, &rx);   /* statement form — ordered flag must be preserved */

    intptr_t values[] = {1, 2, 3, 4, 5};
    int n = sizeof(values) / sizeof(values[0]);

    {
        CCNursery* __cc_nursery74 = @create(NULL) @destroy;
        if (!__cc_nursery74) abort();
        (void)__cc_nursery74->close_on(tx);

        for (int i = 0; i < n; i++) {
            intptr_t v = values[i];
            cc_channel_send_task(tx, () => [v] compute(v));
        }
    
    }

    intptr_t result;
    int idx = 0;
    while (cc_io_avail(chan_recv(rx, &result)) && idx < n) {
        intptr_t expected = values[idx] * 2;
        if (result != expected) {
            printf("FAIL stmt-form ordered chan_recv: pos %d expected %lld got %lld\n",
                   idx, (long long)expected, (long long)result);
            chan_free(rx);
            return 0;
        }
        idx++;
    }
    chan_free(rx);
    if (idx != n) { printf("FAIL stmt-form: got %d values, expected %d\n", idx, n); return 0; }
    return 1;
}

/* -----------------------------------------------------------------------
 * 3. New: typed ordered channel, expression-form channel_pair
 * ----------------------------------------------------------------------- */
static int test_typed_ordered_expr_form(void) {
    intptr_t[~8 >] tx;
    intptr_t[~8 ordered <] rx;
    CCChan* ch = cc_channel_pair(&tx, &rx);   /* expression form */

    intptr_t values[] = {7, 14, 21, 28};
    int n = sizeof(values) / sizeof(values[0]);

    {
        CCNursery* __cc_nursery75 = @create(NULL) @destroy;
        if (!__cc_nursery75) abort();
        (void)__cc_nursery75->close_on(tx);

        for (int i = 0; i < n; i++) {
            intptr_t v = values[i];
            cc_channel_send_task(tx, () => [v] compute(v));
        }
    
    }

    intptr_t result;
    int idx = 0;
    while (cc_io_avail(chan_recv(rx, &result)) && idx < n) {
        intptr_t expected = values[idx] * 2;
        if (result != expected) {
            printf("FAIL expr-form ordered chan_recv: pos %d expected %lld got %lld\n",
                   idx, (long long)expected, (long long)result);
            cc_chan_free(ch);
            return 0;
        }
        idx++;
    }
    cc_chan_free(ch);
    if (idx != n) { printf("FAIL expr-form: got %d values, expected %d\n", idx, n); return 0; }
    return 1;
}

/* -----------------------------------------------------------------------
 * 4. Ordered task channel preserves rich result types without glue helpers
 * ----------------------------------------------------------------------- */
static int test_ordered_result_payload(void) {
    int !>(CCIoError)[~8 >] result_tx;
    int !>(CCIoError)[~8 ordered <] result_rx;
    CCChan* ch = cc_channel_pair(&result_tx, &result_rx);

    int values[] = {2, -1, 5};
    int expected_ok[] = {6, 0, 15};
    int expected_is_err[] = {0, 1, 0};
    int n = sizeof(values) / sizeof(values[0]);

    {
        CCNursery* __cc_nursery76 = @create(NULL) @destroy;
        if (!__cc_nursery76) abort();
        (void)__cc_nursery76->close_on(result_tx);

        for (int i = 0; i < n; i++) {
            int v = values[i];
            cc_channel_send_task(result_tx, () => [v] compute_result(v));
        }
    
    }

    int !>(CCIoError) result;
    int idx = 0;
    while (cc_io_avail(chan_recv(result_rx, &result)) && idx < n) {
        if (expected_is_err[idx]) {
            if (!cc_is_err(result)) {
                printf("FAIL result-payload: pos %d expected error\n", idx);
                cc_chan_free(ch);
                return 0;
            }
        } else {
            if (cc_is_err(result) || cc_unwrap(result) != expected_ok[idx]) {
                printf("FAIL result-payload: pos %d expected %d\n", idx, expected_ok[idx]);
                cc_chan_free(ch);
                return 0;
            }
        }
        idx++;
    }
    cc_chan_free(ch);
    if (idx != n) { printf("FAIL result-payload: got %d values, expected %d\n", idx, n); return 0; }
    return 1;
}

int main(void) {
    int ok = 1;

    if (!test_legacy_ordered_recv())     { ok = 0; }
    if (!test_typed_ordered_stmt_form()) { ok = 0; }
    if (!test_typed_ordered_expr_form()) { ok = 0; }
    if (!test_ordered_result_payload())  { ok = 0; }

    if (ok) {
        printf("ordered_channel_smoke: PASS\n");
    }
    return ok ? 0 : 1;
}
