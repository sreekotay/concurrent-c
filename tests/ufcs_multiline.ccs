#include <ccc/std/prelude.cch>

// UFCS smoke: validate compiler-side overload selection for cc_std_out.write:
// - cc_std_out.write("literal") -> cc_std_out_write(cc_slice_from_buffer(...))
// - cc_std_out.write(s) -> cc_std_out_write_string(&s)
int main(void) {
    {
        CCArena arena_storage = @create(kilobytes(4)) @destroy;
        if (!arena_storage.base) abort();
        CCArena* arena = &arena_storage;
        CCString s = CCString_new(arena);

        // Multi-line UFCS call (args across lines)
        s.append(
            "multi-line\n"
        );

        cc_std_out.write("literal\n");
        cc_std_out.write(s);
    }
    return 0;
}


