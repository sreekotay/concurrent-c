/* Direct-@async variant of the request/reply handoff test.
 *
 * Guards against the "[mco overflow] coroutine stack overflow"
 * regression that used to fire 100% of the time when an @async function
 * bodies used cc_channel_send / cc_channel_recv (which expand to a
 * synchronous blocking path internally) while running on the V2
 * scheduler with several worker threads.  Root cause: sched_v2_yield /
 * sched_v2_park were identifying the current fiber through
 * `tls_v2_current_fiber`, which on macOS arm64 could yield a stale
 * pointer to a fiber_v2 that had previously run on a *different* worker
 * thread.  The resulting mco_yield(f->coro) passed a coro whose stack
 * range didn't match the SP we were actually on, and minicoro
 * correctly (and confusingly) reported it as a stack overflow.
 *
 * Fixed in cc/runtime/sched_v2.c by sourcing the coro from
 * mco_running() directly (minicoro publishes its own __thread slot
 * inside _mco_prepare_jumpin on the resuming thread), and deriving the
 * fiber from mco_get_user_data(co).  Stress the path with a mix of
 * send/recv, worker count > 1, and channel capacities that force both
 * park and resume across migrations. */
#include <ccc/cc_runtime.cch>
#include <ccc/cc_channel.cch>
#include <ccc/cc_atomic.cch>
#include <ccc/cc_nursery.cch>
#include <ccc/std/task.cch>

#include <stdio.h>
#include <stdlib.h>

#define REQUESTS 16
#define REQUEST_CHAN_CAP 4

typedef struct {
    int request_id;
    int expected_reply;
} HandoffRequest;

static cc_atomic_int g_errors = 0;
static cc_atomic_int g_owner_seen = 0;

static int expected_reply_value(int request_id) {
    return request_id * 17;
}

@async int handoff_owner(CCChanRx req_rx, CCChanTx reply_tx) {
    HandoffRequest* req = NULL;
    while (cc_io_avail(cc_channel_recv(req_rx, &req))) {
        if (!req) continue;
        cc_atomic_fetch_add(&g_owner_seen, 1);

        int expected = expected_reply_value(req->request_id);
        if (req->expected_reply != expected) {
            cc_atomic_fetch_add(&g_errors, 1);
        }

        if (!cc_io_avail(cc_channel_send(reply_tx, req->expected_reply))) {
            cc_atomic_fetch_add(&g_errors, 1);
        }

        free(req);
    }
    return 0;
}

@async int handoff_client(CCChanTx req_tx, CCChanRx reply_rx) {
    HandoffRequest* req = NULL;
    int expected = 0;
    int reply = -1;
    for (int request_id = 1; request_id <= REQUESTS; ++request_id) {
        req = malloc(sizeof(HandoffRequest));
        if (!req) { cc_atomic_fetch_add(&g_errors, 1); return 1; }

        expected = expected_reply_value(request_id);
        req->request_id = request_id;
        req->expected_reply = expected;

        if (!cc_io_avail(cc_channel_send(req_tx, req))) {
            cc_atomic_fetch_add(&g_errors, 1);
            free(req);
            return 2;
        }

        reply = -1;
        if (!cc_io_avail(cc_channel_recv(reply_rx, &reply))) {
            cc_atomic_fetch_add(&g_errors, 1);
            return 3;
        }
        if (reply != expected) {
            cc_atomic_fetch_add(&g_errors, 1);
            return 4;
        }
    }
    cc_channel_close(req_tx);
    return 0;
}

int main(void) {
    cc_sched_set_num_workers(4);
    cc_atomic_store(&g_errors, 0);
    cc_atomic_store(&g_owner_seen, 0);

    HandoffRequest*[~REQUEST_CHAN_CAP N:1 >] req_tx;
    HandoffRequest*[~REQUEST_CHAN_CAP N:1 <] req_rx;
    CCChan* req_ch = cc_channel_pair(&req_tx, &req_rx);
    if (!req_ch) return 10;
    @defer req_ch.free();
    CCChanTx req_tx_raw = req_tx;
    CCChanRx req_rx_raw = req_rx;

    int[~1 >] reply_tx_h;
    int[~1 <] reply_rx_h;
    CCChan* reply_ch = cc_channel_pair(&reply_tx_h, &reply_rx_h);
    if (!reply_ch) return 11;
    @defer reply_ch.free();
    CCChanTx reply_tx_raw = reply_tx_h;
    CCChanRx reply_rx_raw = reply_rx_h;

    {
        CCNursery* n = @create(NULL) @destroy;
        if (!n) return 12;
        if (n->spawn_async(handoff_owner(req_rx_raw, reply_tx_raw)) != 0) return 13;
        if (n->spawn_async(handoff_client(req_tx_raw, reply_rx_raw)) != 0) return 14;
    }

    int expected_total = REQUESTS;
    int errors = cc_atomic_load(&g_errors);
    int owner_seen = cc_atomic_load(&g_owner_seen);
    if (errors != 0) return 20;
    if (owner_seen != expected_total) return 21;

    printf("async_request_reply_handoff_smoke: PASS (%d requests)\n", expected_total);
    return 0;
}
