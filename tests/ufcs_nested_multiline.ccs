#include <ccc/std/prelude.cch>

int main(void) {
    {
        CCArena arena_storage = @create(kilobytes(4)) @destroy;
        if (!arena_storage.base) abort();
        CCArena* arena = &arena_storage;
        CCString s = cc_string_new();
        s.append("nested\n", arena);

        // Outer UFCS call spans multiple lines and contains an inner UFCS call.
        cc_std_out.write(
            s.as_slice()
        );
    }
    return 0;
}


