/*
 * Smoke test: Channel operations in concurrent spawns
 * Tests poll/wait integration with fiber scheduling.
 */
#include <ccc/cc_runtime.cch>
#include <stdio.h>

int main(void) {
    int[~ >] tx;
    int[~ <] rx;
    cc_channel_pair(&tx, &rx);
    
    int sent = 0;
    int received = 0;
    
    {
        CCNursery* __cc_nursery2 = @create(NULL) @destroy;
        if (!__cc_nursery2) abort();
        (void)__cc_nursery2->close_on(tx);

        __cc_nursery2->spawn(@unsafe () => [tx, &sent] {
            for (int i = 0; i < 10; i++) tx.send(i);
            sent = 10;
        });
        
        __cc_nursery2->spawn(@unsafe () => [rx, &received] {
            int v;
            for (int i = 0; i < 10; i++) {
                rx.recv(&v);
                received += v;
            }
        });
    
    }
    
    /* 0+1+2+...+9 = 45 */
    if (sent == 10 && received == 45) {
        printf("async_channel_poll_wait_smoke: PASS\n");
        return 0;
    } else {
        printf("async_channel_poll_wait_smoke: FAIL (sent=%d, received=%d)\n", sent, received);
        return 1;
    }
}
