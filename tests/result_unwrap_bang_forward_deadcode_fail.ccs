// Fail: code after `@err(e);` in the same block is unreachable (the
// forward never returns), so it must be a compile error.
#include <stdio.h>
bool !> (CCError) f(void) { return cc_err(CC_ERR_NOT_FOUND, "x"); }
int main(void) {
    @errhandler(CCError e) { (void)e; return 0; }
    f() !> (e) {
        @err(e);
        printf("dead\n");
    };
    return 0;
}
