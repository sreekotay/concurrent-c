// Smoke: ?> with break as never-typed RHS inside a loop.
#include <stdio.h>

static int g_last;

int !> (CCError) always_err(void) {
    return cc_err(CC_ERR_NOT_FOUND, "always_err");
}

int !> (CCError) always_ok(void) {
    return cc_ok(99);
}

int main(void) {
    int total = 0;
    for (int i = 0; i < 5; i++) {
        int v = (i == 3 ? always_err() : always_ok()) ?> break;
        total += v;
        g_last = i;
    }
    printf("total=%d last=%d\n", total, g_last);
    return 0;
}
