// Slice 7: without CC_STRICT_RESULT_UNWRAP=1, a bare call to a
// result-returning function is still accepted — the result value is
// evaluated and discarded.  Phase-1 safety: existing code compiles.
#include <stdio.h>

int !> (CCError) f(void) {
    return cc_err(CC_ERR_NOT_FOUND, "x");
}

int main(void) {
    f();
    printf("done\n");
    return 0;
}
