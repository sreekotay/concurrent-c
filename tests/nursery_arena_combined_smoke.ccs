/* Test: @nursery and @arena in the same function.
   
   This tests the EditBuffer fix - previously nursery and arena used the same AST
   but nursery would modify the source first, leaving arena with stale offsets.
   Now both collect edits into a shared EditBuffer and apply them together.
*/

#include <ccc/std/prelude.cch>
#include <stdio.h>

void test_nursery_then_arena(void) {
    printf("test_nursery_then_arena:\n");
    
    {
        CCNursery* __cc_nursery60 = @create(NULL) @destroy;
        if (!__cc_nursery60) abort();

        __cc_nursery60->spawn(() => {
            printf("  spawned task\n");
        });
    
    }
    
    {
        CCArena __cc_arena7 = @create(kilobytes(4)) @destroy;
        if (!__cc_arena7.base) abort();
        CCArena* a = &__cc_arena7;
        int* p = cc_arena_alloc_T(int, a);
        *p = 42;
        printf("  arena allocated: %d\n", *p);
    
    }
    
    printf("  done\n");
}

void test_arena_then_nursery(void) {
    printf("test_arena_then_nursery:\n");
    
    {
        CCArena __cc_arena8 = @create(kilobytes(4)) @destroy;
        if (!__cc_arena8.base) abort();
        CCArena* a = &__cc_arena8;
        int* p = cc_arena_alloc_T(int, a);
        *p = 123;
        printf("  arena allocated: %d\n", *p);
    
    }
    
    {
        CCNursery* __cc_nursery61 = @create(NULL) @destroy;
        if (!__cc_nursery61) abort();

        __cc_nursery61->spawn(() => {
            printf("  spawned task\n");
        });
    
    }
    
    printf("  done\n");
}

void test_interleaved(void) {
    printf("test_interleaved:\n");
    
    {
        CCArena __cc_arena9 = @create(kilobytes(4)) @destroy;
        if (!__cc_arena9.base) abort();
        CCArena* a1 = &__cc_arena9;
        printf("  arena a1 active\n");
        
        {
            CCNursery* __cc_nursery62 = @create(NULL) @destroy;
            if (!__cc_nursery62) abort();

            __cc_nursery62->spawn(() => {
                printf("  spawned inside arena\n");
            });
        
        }
        
        printf("  nursery inside arena done\n");
    
    }
    
    {
        CCNursery* __cc_nursery63 = @create(NULL) @destroy;
        if (!__cc_nursery63) abort();

        {
            CCArena __cc_arena10 = @create(kilobytes(4)) @destroy;
            if (!__cc_arena10.base) abort();
            CCArena* a2 = &__cc_arena10;
            printf("  arena inside nursery\n");
        
        }
        
        __cc_nursery63->spawn(() => {
            printf("  spawned after arena\n");
        });
    
    }
    
    printf("  done\n");
}

int main(void) {
    test_nursery_then_arena();
    test_arena_then_nursery();
    test_interleaved();
    printf("All combined tests passed!\n");
    return 0;
}
