#include <ccc/cc_nursery.cch>
// Smoke: nested closures should be *recorded* in stub AST (Phase 2).

int g = 0;
int x = 1;

int main(void) {
    {
        CCNursery* __cc_nursery45 = @create(NULL) @destroy;
        if (!__cc_nursery45) abort();

        __cc_nursery45->spawn (() => {
            {
                CCNursery* __cc_nursery46 = @create(NULL) @destroy;
                if (!__cc_nursery46) abort();

                __cc_nursery46->spawn (() => { g = x; });
            
            }
        });
    
    }
    return 0;
}

