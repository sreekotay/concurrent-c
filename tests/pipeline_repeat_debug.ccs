/*
 * Debug variant of stress/pipeline_repeat.ccs that counts what each
 * stage sent and received, so we can see where items are being lost.
 */
#include <ccc/cc_runtime.cch>
#include <ccc/cc_atomic.cch>
#include <stdio.h>

#define NUM_ITEMS 100
#define REPEATS   200

int[~8 >] g_tx0, g_tx1, g_tx2, g_tx3, g_tx4;
int[~8 <] g_rx0, g_rx1, g_rx2, g_rx3, g_rx4;
CCChan* g_ch0;
CCChan* g_ch1;
CCChan* g_ch2;
CCChan* g_ch3;
CCChan* g_ch4;
cc_atomic_int g_s0, g_s1, g_s2, g_s3, g_s4;   /* sends per stage */
cc_atomic_int g_r1, g_r2, g_r3, g_r4, g_r5;   /* recvs per stage */
cc_atomic_int g_out_count;
cc_atomic_int g_out_sum;

int main(void) {
    for (int iter = 0; iter < REPEATS; iter++) {
        g_ch0 = cc_channel_pair(&g_tx0, &g_rx0);
        g_ch1 = cc_channel_pair(&g_tx1, &g_rx1);
        g_ch2 = cc_channel_pair(&g_tx2, &g_rx2);
        g_ch3 = cc_channel_pair(&g_tx3, &g_rx3);
        g_ch4 = cc_channel_pair(&g_tx4, &g_rx4);
        cc_atomic_store(&g_s0, 0); cc_atomic_store(&g_s1, 0);
        cc_atomic_store(&g_s2, 0); cc_atomic_store(&g_s3, 0);
        cc_atomic_store(&g_s4, 0);
        cc_atomic_store(&g_r1, 0); cc_atomic_store(&g_r2, 0);
        cc_atomic_store(&g_r3, 0); cc_atomic_store(&g_r4, 0);
        cc_atomic_store(&g_r5, 0);
        cc_atomic_store(&g_out_count, 0);
        cc_atomic_store(&g_out_sum, 0);

        {
            CCNursery* __n = @create(NULL) @destroy;
            if (!__n) abort();

            __n->spawn(() => {
                for (int i = 0; i < NUM_ITEMS; i++) {
                    chan_send(g_tx0, i);
                    cc_atomic_fetch_add(&g_s0, 1);
                }
                chan_close(g_tx0);
            });
            __n->spawn(() => {
                int v;
                while (cc_io_avail(chan_recv(g_rx0, &v))) {
                    cc_atomic_fetch_add(&g_r1, 1);
                    chan_send(g_tx1, v+1);
                    cc_atomic_fetch_add(&g_s1, 1);
                }
                chan_close(g_tx1);
            });
            __n->spawn(() => {
                int v;
                while (cc_io_avail(chan_recv(g_rx1, &v))) {
                    cc_atomic_fetch_add(&g_r2, 1);
                    chan_send(g_tx2, v+1);
                    cc_atomic_fetch_add(&g_s2, 1);
                }
                chan_close(g_tx2);
            });
            __n->spawn(() => {
                int v;
                while (cc_io_avail(chan_recv(g_rx2, &v))) {
                    cc_atomic_fetch_add(&g_r3, 1);
                    chan_send(g_tx3, v+1);
                    cc_atomic_fetch_add(&g_s3, 1);
                }
                chan_close(g_tx3);
            });
            __n->spawn(() => {
                int v;
                while (cc_io_avail(chan_recv(g_rx3, &v))) {
                    cc_atomic_fetch_add(&g_r4, 1);
                    chan_send(g_tx4, v+1);
                    cc_atomic_fetch_add(&g_s4, 1);
                }
                chan_close(g_tx4);
            });
            __n->spawn(() => {
                int v;
                while (cc_io_avail(chan_recv(g_rx4, &v))) {
                    cc_atomic_fetch_add(&g_r5, 1);
                    cc_atomic_fetch_add(&g_out_count, 1);
                    cc_atomic_fetch_add(&g_out_sum, v);
                }
            });
        }

        int expected = (NUM_ITEMS*(NUM_ITEMS-1))/2 + 4*NUM_ITEMS;
        int c = cc_atomic_load(&g_out_count);
        int s = cc_atomic_load(&g_out_sum);
        if (c != NUM_ITEMS || s != expected) {
            fprintf(stderr, "FAIL iter %d: count=%d sum=%d (expected %d/%d)\n",
                    iter, c, s, NUM_ITEMS, expected);
            fprintf(stderr, "  s0=%d  r1=%d s1=%d  r2=%d s2=%d  r3=%d s3=%d  r4=%d s4=%d  r5=%d\n",
                    cc_atomic_load(&g_s0),
                    cc_atomic_load(&g_r1), cc_atomic_load(&g_s1),
                    cc_atomic_load(&g_r2), cc_atomic_load(&g_s2),
                    cc_atomic_load(&g_r3), cc_atomic_load(&g_s3),
                    cc_atomic_load(&g_r4), cc_atomic_load(&g_s4),
                    cc_atomic_load(&g_r5));
            return 1;
        }

        cc_chan_free(g_ch0); cc_chan_free(g_ch1); cc_chan_free(g_ch2);
        cc_chan_free(g_ch3); cc_chan_free(g_ch4);
    }
    printf("pipeline_repeat_debug: OK\n");
    return 0;
}
