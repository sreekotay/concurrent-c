/* Test UFCS method calls on struct field containers */
#include <ccc/std/prelude.cch>
#include <stdio.h>

typedef struct {
    Vec<int> items;
} Container;

int main(void) {
    CCArena arena = cc_arena_heap(kilobytes(4));
    
    Container c;
    c.items = vec_new<int>(&arena);
    
    /* Value receiver on a struct field should lower with &field. */
    c.items.push(10);
    c.items.push(20);
    c.items.push(30);
    
    if (Vec_int_len(&c.items) != 3) {
        printf("FAIL: expected 3 elements\n");
        return 1;
    }
    
    int? val = c.items.get(1);
    if (!val.has || *val != 20) {
        printf("FAIL: get(1) expected 20\n");
        return 1;
    }
    
    /* Pointer receiver on a pointer-valued field should pass the field directly. */
    typedef struct {
        Vec<int>* items;
    } PtrContainer;
    PtrContainer pc;
    pc.items = &c.items;
    pc.items->push(40);
    
    if (Vec_int_len(&c.items) != 4) {
        printf("FAIL: expected 4 elements after ptr push\n");
        return 1;
    }
    
    printf("ok\n");
    cc_arena_free(&arena);
    return 0;
}
