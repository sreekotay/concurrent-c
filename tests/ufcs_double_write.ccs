#include <ccc/std/prelude.cch>

int main(void) {
    {
        CCArena arena_storage = @create(kilobytes(4)) @destroy;
        if (!arena_storage.base) abort();
        CCArena* arena = &arena_storage;
        CCString s = cc_string_new(arena);
        s.append("double\n");

        // Two UFCS calls with the same method in the same "window".
        cc_std_out.write("A\n");
        cc_std_out.write("B\n");
        cc_std_out.write(s);
    }
    return 0;
}


