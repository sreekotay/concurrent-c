#include <ccc/std/prelude.cch>
#include <ccc/cc_ufcs.cch>

static int g_destroyed = 0;
static int g_pre_destroyed = 0;
static int g_pre_before_body = 0;

static size_t arena_avail(CCArena* arena) {
    return cc_arena_remaining(arena);
}

static void mark_arena_pre_destroy(CCArena* arena) {
    if (arena) {
        g_pre_destroyed += 1;
        if (g_destroyed == 0) g_pre_before_body = 1;
    }
}

@comptime {
    (void)cc_type_register("CCArena", (CCTypeHooks){
        .create = cc_type_create_overloads("cc_arena_create", "cc_arena_create_init"),
        .destroy = cc_type_destroy_hooks("mark_arena_pre_destroy", "cc_arena_destroy"),
        .ufcs = (recv_type, method, mode, argv, arg_types, arena) => {
            (void)recv_type;
            (void)mode;
            (void)argv;
            (void)arg_types;
            (void)arena;
            if (CCSlice_eq_cstr(&method, "avail")) {
                return cc_slice_from_buffer((void*)"arena_avail", sizeof("arena_avail") - 1);
            }
            return cc_slice_empty();
        },
    });
}

int main(void) {
    {
        CCArena arena = @create(256) @destroy {
            g_destroyed += 1;
        };
        if (!arena.base) return 1;
        if (arena.avail() == 0) return 2;
        if (!cc_arena_alloc_T_count(char, &arena, 16)) return 3;
    }

    if (g_destroyed != 1) return 4;
    if (g_pre_destroyed != 1) return 7;
    if (g_pre_before_body != 1) return 8;

    {
        char backing[64];
        CCArena arena = @create(backing, sizeof(backing)) @detach;
        if (!arena.base) return 5;
        if (arena.avail() != sizeof(backing)) return 6;
        cc_arena_destroy(&arena);
    }

    return 0;
}
