/*
 * GoBench GoKer: grpc#1275 (channel deadlock).
 * Ported kernel: reader waits on channel, closer never signals.
 */
#include <ccc/cc_runtime.cch>
#include <pthread.h>
#include <stdio.h>
#include <errno.h>

static CCChan* g_recv_ch = NULL;
static CCChan* g_done_ch = NULL;

static void* reader_thread(void* arg) {
    (void)arg;
    int v = 0;
    (void)cc_chan_recv(g_recv_ch, &v, sizeof(v)); /* blocks */
    v = 1;
    cc_chan_send(g_done_ch, &v, sizeof(v));
    return NULL;
}

int main(void) {
    CCChan* recv_ch = cc_chan_create(0);
    CCChan* done_ch = cc_chan_create(1);
    if (!recv_ch || !done_ch) return 2;
    if (cc_chan_init_elem(recv_ch, sizeof(int)) != 0) return 3;
    if (cc_chan_init_elem(done_ch, sizeof(int)) != 0) return 4;

    pthread_t tid;
    g_recv_ch = recv_ch;
    g_done_ch = done_ch;
    pthread_create(&tid, NULL, reader_thread, NULL);

    int v = 0;
    int rc = 0;
    @with_deadline(millis(20)) {
        rc = cc_chan_recv(done_ch, &v, sizeof(v));
    }

    /* Expect timeout because CloseStream never signals recv. */
    if (rc != ETIMEDOUT) return 10;

    /* Cleanup: unblock reader and join. */
    v = 42;
    cc_chan_send(recv_ch, &v, sizeof(v));
    pthread_join(tid, NULL);

    cc_chan_free(recv_ch);
    cc_chan_free(done_ch);
    printf("gobench goker grpc1275: PASS\n");
    return 0;
}

/*
 * Original GoBench GoKer source:
 * https://raw.githubusercontent.com/goodmorning-coder/gobench/master/gobench/goker/blocking/grpc/1275/grpc1275_test.go
 *
 * package grpc1275
 *
 * import (
 *  "io"
 *  "testing"
 *  "time"
 * )
 *
 * type recvBuffer struct {
 *  c chan bool
 * }
 *
 * func (b *recvBuffer) get() <-chan bool {
 *  return b.c
 * }
 *
 * type recvBufferReader struct {
 *  recv *recvBuffer
 * }
 *
 * func (r *recvBufferReader) Read(p []byte) (int, error) {
 *  select {
 *  case <-r.recv.get(): // G2 block here
 *  }
 *  return 0, nil
 * }
 *
 * type Stream struct {
 *  trReader io.Reader
 * }
 *
 * func (s *Stream) Read(p []byte) (int, error) {
 *  return io.ReadFull(s.trReader, p)
 * }
 *
 * type http2Client struct{}
 *
 * func (t *http2Client) CloseStream(s *Stream) {
 *  // It is the client.CloseSream() method called by the
 *  // main goroutine that should send the message, but it
 *  // is not. The patch is to send out this message.
 * }
 *
 * func (t *http2Client) NewStream() *Stream {
 *  return &Stream{
 *   trReader: &recvBufferReader{
 *    recv: &recvBuffer{
 *     c: make(chan bool),
 *    },
 *   },
 *  }
 * }
 *
 * func testInflightStreamClosing() {
 *  client := &http2Client{}
 *  stream := client.NewStream()
 *  donec := make(chan bool)
 *  go func() { // G2
 *   defer close(donec)
 *   stream.Read([]byte{1})
 *  }()
 *
 *  client.CloseStream(stream)
 *
 *  timeout := time.NewTimer(300 * time.Nanosecond)
 *  select {
 *  case <-donec:
 *   if !timeout.Stop() {
 *    <-timeout.C
 *   }
 *  case <-timeout.C:
 *  }
 * }
 *
 * ///
 * /// G1 G2
 * /// testInflightStreamClosing()
 * /// stream.Read()
 * /// io.ReadFull()
 * /// <- r.recv.get()
 * /// CloseStream()
 * /// <- donec
 * /// ------------G1 timeout, G2 leak---------------------
 * ///
 *
 * func TestGrpc1293(t *testing.T) {
 *  testInflightStreamClosing() // G1
 * }
 */
