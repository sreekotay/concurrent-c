#include <ccc/cc_runtime.cch>
#include <ccc/cc_channel.cch>

/*
 * Idiomatic CC analog of a gRPC shutdown/GOAWAY bug:
 * the reader waits for the GOAWAY/control channel to close, but the close
 * would only happen after owned tasks exit.
 */
int main(void) {
    CCChanTx goaway_tx;
    CCChanRx goaway_rx;
    CCChanTx done_tx;
    CCChanRx done_rx;
    if (cc_chan_pair_create(1, CC_CHAN_MODE_BLOCK, false, sizeof(int), &goaway_tx, &goaway_rx) != 0) return 2;
    if (cc_chan_pair_create(1, CC_CHAN_MODE_BLOCK, false, sizeof(int), &done_tx, &done_rx) != 0) return 3;

    @closing(goaway_tx, done_tx) {
        spawn(() => {
            int code = 0;
            while (cc_io_avail(chan_recv(goaway_rx, &code))) {
                (void)code;
            }
            (void)chan_send(done_tx, 1);
        });
    }

    chan_free(goaway_tx);
    chan_free(done_tx);
    return 0;
}

/*
 * Original GoBench GoReal source material:
 * README: https://raw.githubusercontent.com/goodmorning-coder/gobench/master/gobench/goreal/blocking/grpc/2391/README.md
 * Patch:  https://raw.githubusercontent.com/goodmorning-coder/gobench/master/gobench/goreal/blocking/grpc/2391/bug_patch.diff
 *
 * GoReal stores grpc#2391 as a source patch rather than a standalone Go kernel.
 * The bug material in GoBench is:
 *
 * diff --git a/clientconn.go b/clientconn.go
 * index d0404313..e74f8e40 100644
 * --- a/clientconn.go
 * +++ b/clientconn.go
 * @@ -1066,6 +1066,9 @@ func (ac *addrConn) createTransport(backoffNum int, addr resolver.Address, copts
 *  case <-skipReset: // The outer resetTransport loop will handle reconnection.
 *  return
 *  case <-allowedToReset: // We're in the clear to reset.
 * + ac.mu.Lock()
 * + ac.transport = nil
 * + ac.mu.Unlock()
 *  oneReset.Do(func() { ac.resetTransport(false) })
 *  }
 *  }
 *
 * README description:
 *
 * Some description from developers or pervious reseachers
 *
 * > A deadlock can occur when a GO_AWAY is followed by a connection closure. This
 *  happens because onClose needlessly closes the current ac.transport: if a
 *  GO_AWAY already occured, and the transport was already reset, then the later
 *  closure (of the original address) sets ac.transport - which is now healthy -
 *  to nil.
 */
