#include <ccc/cc_closure.cch>
#include <ccc/cc_nursery.cch>

int main(void) {
    int g = 0;
    int* gp = &g;
    int a = 6;
    int b = 7;

    CCClosure2 c = (int x, int y) => { *gp = x + y; };

    {
        CCNursery* __cc_nursery86 = @create(NULL) @destroy;
        if (!__cc_nursery86) abort();

        (void)cc_nursery_spawn_closure2(__cc_nursery86, c, (intptr_t)a, (intptr_t)b);
    
    }
    return (g == 13) ? 0 : 1;
}

