#include <ccc/std/prelude.cch>
#include <ccc/cc_ufcs.cch>
#include <ccc/cc_type.cch>
#include <assert.h>
#include <stdio.h>

typedef struct {
    int value;
#ifdef CC_PARSER_MODE
    int (*bump)();
#endif
} GenericToy;

typedef struct {
    int value;
#ifdef CC_PARSER_MODE
    int (*bump)();
#endif
} OverrideToy;

typedef struct {
    int value;
#ifdef CC_PARSER_MODE
    int (*bump)();
#endif
} LegacyWildAlpha;

static void generic_toy_bump(GenericToy* toy) {
    toy->value += 1;
}

static void override_toy_legacy_bump(OverrideToy* toy) {
    toy->value += 10;
}

static void override_toy_type_bump(OverrideToy* toy) {
    toy->value += 100;
}

static void legacy_wild_alpha_bump(LegacyWildAlpha* toy) {
    toy->value += 1000;
}

static CCSlice generic_toy_ufcs(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena* arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("generic_toy_", sizeof("generic_toy_") - 1),
        method);
}

static CCSlice override_toy_legacy_ufcs(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena* arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("override_toy_legacy_", sizeof("override_toy_legacy_") - 1),
        method);
}

static CCSlice override_toy_type_ufcs(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena* arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("override_toy_type_", sizeof("override_toy_type_") - 1),
        method);
}

static CCSlice legacy_wild_ufcs(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena* arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("legacy_wild_alpha_", sizeof("legacy_wild_alpha_") - 1),
        method);
}

@comptime {
    (void)cc_ufcs_register("GenericToy", generic_toy_ufcs);
    (void)cc_ufcs_register("OverrideToy", override_toy_legacy_ufcs);
    (void)cc_ufcs_register("LegacyWild*", legacy_wild_ufcs);
    (void)cc_type_register("OverrideToy", (CCTypeHooks){
        .ufcs = override_toy_type_ufcs,
    });
}

int main(void) {
    GenericToy generic = { 1 };
    OverrideToy override = { 1 };
    LegacyWildAlpha wildcard = { 1 };

    generic.bump();
    override.bump();
    wildcard.bump();

    assert(generic.value == 2);
    assert(override.value == 101);
    assert(wildcard.value == 1001);

    printf("comptime_legacy_ufcs_compat_smoke: PASS\n");
    return 0;
}
