#include <ccc/std/prelude.cch>
#include <ccc/cc_ufcs.cch>
#include <ccc/cc_type.cch>
#include <assert.h>
#include <stdio.h>

typedef struct {
    int value;
#ifdef CC_PARSER_MODE
    int (*bump)();
    int (*bump_by)();
#endif
} NamedToy;

typedef struct {
    int value;
#ifdef CC_PARSER_MODE
    int (*bump)();
#endif
} LambdaToy;

static void named_toy_bump(NamedToy* toy) {
    toy->value += 1;
}

static void named_toy_bump_by(NamedToy* toy, int delta) {
    toy->value += delta;
}

static void lambda_toy_bump(LambdaToy* toy) {
    toy->value += 10;
}

static CCSlice named_toy_ufcs_rewrite(CCSlice method, CCSlice mode, CCSliceArray argv, CCArena* arena) {
    (void)mode;
    (void)argv;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("named_toy_", sizeof("named_toy_") - 1),
        method);
}

@comptime {
    (void)cc_type_register("NamedToy", (CCTypeHooks){
        .ufcs = named_toy_ufcs_rewrite,
    });
    (void)cc_type_register("LambdaToy", (CCTypeHooks){
        .ufcs = (method, mode, argv, arena) => {
            (void)mode;
            (void)argv;
            return cc_ufcs_concat2(arena,
                cc_slice_from_buffer("lambda_toy_", sizeof("lambda_toy_") - 1),
                method);
        },
    });
}

int main(void) {
    @arena {
        NamedToy named = { 1 };
        LambdaToy lambda = { 2 };
        CCString s = cc_string_new(arena);

        named.bump();
        named.bump_by(4);
        lambda.bump();
        s.append("ok");

        assert(named.value == 6);
        assert(lambda.value == 12);
        assert(s.len == 2);
    }

    printf("comptime_prelude_ufcs_smoke: PASS\n");
    return 0;
}
