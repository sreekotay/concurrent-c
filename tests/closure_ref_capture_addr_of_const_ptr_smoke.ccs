/* Test (2B): passing &x to a known const T* parameter is allowed (read-only). */
#include <ccc/cc_nursery.cch>
#include <stdio.h>

static void read_only_i32(const int* p) {
    if (p) printf("%d\n", *p);
}

int main(void) {
    int x = 7;

    {
        CCNursery* __cc_nursery49 = @create(NULL) @destroy;
        if (!__cc_nursery49) abort();

        __cc_nursery49->spawn(() => [&x] {
            /* Allowed: callee takes const int* */
            read_only_i32(&x);
        });
    
    }

    return 0;
}
