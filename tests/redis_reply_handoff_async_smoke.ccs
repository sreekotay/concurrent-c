#include <ccc/cc_runtime.cch>
#include <ccc/cc_channel.cch>
#include <ccc/cc_atomic.cch>
#include <ccc/cc_nursery.cch>

#include <stdio.h>
#include <stdlib.h>

#define CLIENTS 32
#define REQUESTS 5000
#define REQUEST_CHAN_CAP 128
#define REPLY_CHAN_CAP 1

typedef struct {
    int client_id;
    int request_id;
    CCChanTx reply_tx;
    CCChan* reply_ch;
} AsyncReplyReq;

static cc_atomic_int g_async_errors = 0;
static cc_atomic_int g_async_clients_left = 0;

static void async_owner(CCChanRx req_rx) {
    AsyncReplyReq* req = NULL;
    while (cc_io_avail(cc_channel_recv(req_rx, &req))) {
        if (!req) continue;
        int reply = req->client_id * 1000000 + req->request_id;
        if (!cc_io_avail(cc_channel_send(req->reply_tx, reply))) {
            cc_atomic_fetch_add(&g_async_errors, 1);
        }
        free(req);
    }
}

@async int async_client_loop(int client_id, CCChanTx req_tx) {
    int[~REPLY_CHAN_CAP 1:1 >] reply_tx;
    int[~REPLY_CHAN_CAP 1:1 <] reply_rx;
    CCChan* reply_ch = cc_channel_pair(&reply_tx, &reply_rx);
    if (!reply_ch) {
        cc_atomic_fetch_add(&g_async_errors, 1);
        return 0;
    }

    for (int request_id = 1; request_id <= REQUESTS; ++request_id) {
        AsyncReplyReq* req = malloc(sizeof(AsyncReplyReq));
        if (!req) {
            cc_atomic_fetch_add(&g_async_errors, 1);
            break;
        }
        req->client_id = client_id;
        req->request_id = request_id;
        req->reply_tx = reply_tx;
        req->reply_ch = reply_ch;

        int send_err = (int)(await cc_channel_send_task(req_tx, req));
        if (send_err != 0) {
            cc_atomic_fetch_add(&g_async_errors, 1);
            free(req);
            break;
        }

        int reply = -1;
        int recv_err = (int)(await cc_channel_recv_task(reply_rx, &reply));
        if (recv_err != 0) {
            cc_atomic_fetch_add(&g_async_errors, 1);
            break;
        }

        int expected = client_id * 1000000 + request_id;
        if (reply != expected) {
            fprintf(stderr,
                    "async reply mismatch client=%d req=%d got=%d expected=%d\n",
                    client_id,
                    request_id,
                    reply,
                    expected);
            cc_atomic_fetch_add(&g_async_errors, 1);
            break;
        }

        if ((request_id & 63) == 0) cc_yield();
    }

    cc_channel_close(reply_tx);
    if (cc_atomic_fetch_sub(&g_async_clients_left, 1) == 1) {
        cc_channel_close(req_tx);
    }
    return 0;
}

int main(void) {
    cc_sched_set_num_workers(8);
    cc_atomic_store(&g_async_errors, 0);
    cc_atomic_store(&g_async_clients_left, CLIENTS);

    AsyncReplyReq*[~REQUEST_CHAN_CAP N:1 >] req_tx;
    AsyncReplyReq*[~REQUEST_CHAN_CAP N:1 <] req_rx;
    CCChan* req_ch = cc_channel_pair(&req_tx, &req_rx);
    if (!req_ch) return 10;
    @defer req_ch.free();

    {
        CCNursery* n = @create(NULL) @destroy;
        if (!n) return 11;

        CCChanRx req_rx_raw = req_rx;
        n->spawn(() => [req_rx_raw] {
            async_owner(req_rx_raw);
        });

        for (int i = 0; i < CLIENTS; ++i) {
            CCChanTx req_tx_raw = req_tx;
            int client_id = i + 1;
            if (cc_nursery_spawn_async(n, async_client_loop(client_id, req_tx_raw)) != 0) {
                fprintf(stderr, "spawn async client failed id=%d\n", client_id);
                return 12;
            }
        }
    }

    if (cc_atomic_load(&g_async_errors) != 0) {
        fprintf(stderr, "redis_reply_handoff_async_smoke: FAIL errors=%d\n", cc_atomic_load(&g_async_errors));
        return 20;
    }

    printf("redis_reply_handoff_async_smoke: PASS\n");
    return 0;
}
