#include <ccc/std/prelude.cch>
#include <assert.h>
#include <stdio.h>
#include <string.h>

static CCSlice demo_policy(CCArena *arena, CCSlice tag, CCSlice value) {
    if (CCSlice_is_empty(&tag)) return value;
    CCString out = CCString_new(arena);
    out.append("[");
    out.append(tag);
    out.append("=");
    out.append(value);
    out.append("]");
    return CCString_persist_slice(arena, &out);
}

static void assert_switch_template_as_slice(int64_t value) {
    switch (1) {
        case 1: {
            CCArena tmp = @create(kilobytes(1)) @destroy;
            CCString hdr_str = @string(`$${value}\r\n`, &tmp);
            char[:0] hdr = hdr_str.as_slice();
            assert(hdr.eq_cstr("$42\r\n"));

            CCString s = @string(`:${value}\r\n`, &tmp);
            char[:0] wire = s.as_slice();
            assert(wire.eq_cstr(":42\r\n"));
            return;
        }
        default:
            abort();
    }
}

int main(void) {
    CCArena arena_storage = @create(kilobytes(8)) @destroy;
    if (!arena_storage.base) abort();
    CCArena *arena = &arena_storage;

    CCString literal = @string("hello", arena);
    char[:0] literal_view = literal.as_slice();
    assert(literal_view.eq_cstr("hello"));

    CCString bridged = @string(42, arena);
    char[:0] bridged_view = bridged.as_slice();
    assert(bridged_view.eq_cstr("42"));

    int age = 37;
    CCString via_ufcs = age.to_str(arena);
    char[:0] via_ufcs_view = via_ufcs.as_slice();
    assert(via_ufcs_view.eq_cstr("37"));

    float zero_f = 0.0f;
    double thousand = 1000.0;
    double sci = 1.2e23;
    double neg_zero = -0.0;

    CCString zero_f_str = zero_f.to_str(arena);
    assert(strcmp(CCString_cstr(&zero_f_str), "0.0") == 0);

    CCString thousand_str = thousand.to_str(arena);
    assert(strcmp(CCString_cstr(&thousand_str), "1000.0") == 0);

    CCString sci_str = sci.to_str(arena);
    assert(strcmp(CCString_cstr(&sci_str), "1.2e+23") == 0);

    CCString neg_zero_str = neg_zero.to_str(arena);
    assert(strcmp(CCString_cstr(&neg_zero_str), "-0.0") == 0);

    CCString lit_dollar = @string(demo_policy, `Price: $100`, arena);
    assert(strcmp(CCString_cstr(&lit_dollar), "Price: $100") == 0);

    CCString esc_brace = @string(demo_policy, `\${not_a_slot}`, arena);
    assert(strcmp(CCString_cstr(&esc_brace), "${not_a_slot}") == 0);

    CCString esc_tilde = @string(demo_policy, `\$~meta{not_a_slot}`, arena);
    assert(strcmp(CCString_cstr(&esc_tilde), "$~meta{not_a_slot}") == 0);

    int slot = 99;
    CCString one_bs_slot = @string(demo_policy, `\\${slot}`, arena);
    assert(strcmp(CCString_cstr(&one_bs_slot), "\\" "99") == 0);

    const char *name = "Ada";
    CCString plain_tpl = @string(`name=${name}; age=${age}`, arena);
    assert(strcmp(CCString_cstr(&plain_tpl), "name=Ada; age=37") == 0);

    CCString float_tpl = @string(`zero=${zero_f}; sci=${sci}`, arena);
    assert(strcmp(CCString_cstr(&float_tpl), "zero=0.0; sci=1.2e+23") == 0);

    CCString plain_multiline = @string(`
name=${name}
age=${age}`, arena);
    char[:0] plain_multiline_view = plain_multiline.as_slice();
    assert(plain_multiline_view.eq_cstr("\nname=Ada\nage=37"));

    CCString tpl = @string(demo_policy, `name=${name}; age=$~meta{age+10}`, arena);
    assert(strcmp(CCString_cstr(&tpl), "name=Ada; age=[meta=47]") == 0);

    CCString multiline = @string(demo_policy, `
name=${name}
age=$~meta{age}`, arena);
    char[:0] multiline_view = multiline.as_slice();
    assert(multiline_view.eq_cstr("\nname=Ada\nage=[meta=37]"));

    assert_switch_template_as_slice(42);

    printf("string_template_smoke: PASS\n");
    return 0;
}
