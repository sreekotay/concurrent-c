#include <ccc/cc_closure.cch>
#include <ccc/cc_nursery.cch>

int main(void) {
    int g = 0;
    int* gp = &g;
    int a = 6;
    int b = 7;

    CCClosure2 c = (x, y) => { int* px = (int*)x; int* py = (int*)y; if (px && py) *gp = *px + *py; };

    {
        CCNursery* __cc_nursery87 = @create(NULL) @destroy;
        if (!__cc_nursery87) abort();

        (void)cc_nursery_spawn_closure2(__cc_nursery87, c, (intptr_t)&a, (intptr_t)&b);
    
    }
    return (g == 13) ? 0 : 1;
}

