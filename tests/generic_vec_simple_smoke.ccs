/* Minimal test for CCVec::[int] generic syntax - NO UFCS VERSION */
#include <ccc/std/prelude.cch>
#include <stdio.h>

int main(void) {
    CCArena arena = cc_arena_heap(kilobytes(4));
    if (!arena.base) return 1;

    /* Use CCVec::[int] generic syntax - triggers codegen declaration */
    CCVec::[int] v = cc_vec_new::[int](&arena);
    
    /* Use explicit function calls (no UFCS) */
    CCVec_int_push(&v, 10);
    CCVec_int_push(&v, 20);
    CCVec_int_push(&v, 30);
    
    if (CCVec_int_len(&v) != 3) {
        fprintf(stderr, "FAIL: expected len=3\n");
        return 2;
    }
    
    /* Test optional-returning get with explicit call */
    int? val = CCVec_int_get(&v, 0);
    if (!val.has) {
        fprintf(stderr, "FAIL: get returned None\n");
        return 3;
    }
    if (*val != 10) {
        fprintf(stderr, "FAIL: expected 10\n");
        return 4;
    }

    printf("generic_vec_simple_smoke ok\n");
    
    cc_arena_free(&arena);
    return 0;
}
