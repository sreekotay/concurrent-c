#include <ccc/cc_runtime.cch>
#include <ccc/cc_closure.cch>
#include <ccc/std/task.cch>
#include <pthread.h>

typedef struct {
    intptr_t tid;
    int value;
} Pair;

static intptr_t g_main_tid = 0;

static Pair make_pair(int value) {
    Pair p = { .tid = (intptr_t)pthread_self(), .value = value };
    return p;
}

@async int f(void) {
    Pair p = {0};
    p = make_pair(42);
    return (p.tid == g_main_tid) ? 0 : p.value;
}

int main(void) {
    g_main_tid = (intptr_t)pthread_self();
    int r = cc_block_on(int, f());
    return (r == 42) ? 0 : 1;
}
