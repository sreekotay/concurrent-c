#include <ccc/cc_runtime.cch>
#include <ccc/cc_closure.cch>
#include <ccc/std/task.cch>

int g = 0;

@async int noop(int v) { return v; }

@async int f(void) {
    g = 0;
    {
        CCNursery* __cc_nursery1 = @create(NULL) @destroy;
        if (!__cc_nursery1) abort();

        int x = await noop(7);
        g = x;
        __cc_nursery1->spawn(() => { g = g + 1; });
    
    }
    return g;
}

int main(void) {
    CCTaskIntptr t = f();
    intptr_t r = cc_block_on_intptr(t);
    return (r == 8) ? 0 : 1;
}

