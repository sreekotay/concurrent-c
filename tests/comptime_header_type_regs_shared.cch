#ifndef TESTS_COMPTIME_HEADER_TYPE_REGS_SHARED_H
#define TESTS_COMPTIME_HEADER_TYPE_REGS_SHARED_H

#include <ccc/std/prelude.cch>

static CCSlice header_registered_arena_ufcs(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena* arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    (void)arena;
    if (CCSlice_eq_cstr(&method, "avail")) {
        return cc_slice_from_buffer((void*)"cc_arena_remaining", sizeof("cc_arena_remaining") - 1);
    }
    return cc_slice_empty();
}

@comptime {
    (void)cc_type_register("CCArena", (CCTypeHooks){
        .create = cc_type_create_overloads("cc_arena_create", "cc_arena_fixed_buffer"),
        .destroy = cc_type_destroy_call("cc_arena_destroy"),
        .ufcs = header_registered_arena_ufcs,
    });
}

#endif
