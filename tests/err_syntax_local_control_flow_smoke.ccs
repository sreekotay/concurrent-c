// Smoke: local @err(e){break/continue;} on =<! runs at the @err site
#include <stdio.h>

static int g_break_kind;
static int g_break_steps;
static int g_continue_hits;
static int g_continue_steps;

bool !> (CCError) always_err_bool(void) {
    return cc_err(CC_ERR_NOT_FOUND, "always_err_bool");
}

int main(void) {
    for (int i = 0; i < 3; i++) {
        g_break_steps++;
        bool avail =<! always_err_bool() @err(CCError e) {
            g_break_kind = 100 + e.kind;
            break;
        };
        if (!avail) g_break_steps += 1000;
    }

    for (int i = 0; i < 3; i++) {
        g_continue_steps++;
        bool avail =<! always_err_bool() @err(CCError e) {
            (void)e;
            g_continue_hits++;
            continue;
        };
        if (!avail) g_continue_steps += 1000;
    }

    printf("break_kind=%d break_steps=%d continue_hits=%d continue_steps=%d\n",
           g_break_kind, g_break_steps, g_continue_hits, g_continue_steps);
    return 0;
}
