/*
 * Lost-wake stress for the V2 hybrid path.
 *
 * Covers pre-park wake, post-park wake, and sender-vs-close races while the
 * receiver is running on the distinct V2 scheduler backend.
 */
#include <ccc/cc_runtime.cch>
#include <ccc/cc_channel.cch>
#include <ccc/cc_atomic.cch>

#include <errno.h>
#include <stdio.h>

#define REPEATS 800

static cc_atomic_int g_errors = 0;
static cc_atomic_int g_data = 0;
static cc_atomic_int g_closed = 0;

int main(void) {
    cc_sched_set_num_workers(2);

    for (int rep = 0; rep < REPEATS; rep++) {
        if ((rep % 200) == 0) {
            fprintf(stderr, "v2 lostwake iter %d/%d\n", rep, REPEATS);
        }

        {
            int[~ >] tx;
            int[~ <] rx;
            CCChan* ch = cc_channel_pair(&tx, &rx);
            {
                CCNursery* n = @create(NULL) @destroy;
                if (!n) abort();

                n->spawnhybrid(() => [rx] {
                    int v = -1;
                    int rc = cc_chan_recv(rx.raw, &v, sizeof(int));
                    if (rc == 0 && v == 7) cc_atomic_fetch_add(&g_data, 1);
                    else cc_atomic_fetch_add(&g_errors, 1);
                });
                n->spawn(() => [tx] {
                    int v = 7;
                    int rc = cc_chan_send(tx.raw, &v, sizeof(int));
                    if (rc != 0) cc_atomic_fetch_add(&g_errors, 1);
                });
            }
            tx.close();
            cc_chan_free(ch);
        }

        {
            int[~ >] tx;
            int[~ <] rx;
            CCChan* ch = cc_channel_pair(&tx, &rx);
            {
                CCNursery* n = @create(NULL) @destroy;
                if (!n) abort();

                n->spawnhybrid(() => [rx] {
                    int v = -1;
                    int rc = cc_chan_recv(rx.raw, &v, sizeof(int));
                    if (rc == 0 && v == 11) cc_atomic_fetch_add(&g_data, 1);
                    else cc_atomic_fetch_add(&g_errors, 1);
                });
                n->spawn(() => [tx] {
                    cc_sleep_ms(1);
                    int v = 11;
                    int rc = cc_chan_send(tx.raw, &v, sizeof(int));
                    if (rc != 0) cc_atomic_fetch_add(&g_errors, 1);
                });
            }
            tx.close();
            cc_chan_free(ch);
        }

        {
            int[~ >] tx;
            int[~ <] rx;
            CCChan* ch = cc_channel_pair(&tx, &rx);
            {
                CCNursery* n = @create(NULL) @destroy;
                if (!n) abort();

                n->spawnhybrid(() => [rx] {
                    int v = -1;
                    int rc = cc_chan_recv(rx.raw, &v, sizeof(int));
                    if (rc == 0) cc_atomic_fetch_add(&g_data, 1);
                    else if (rc == EPIPE) cc_atomic_fetch_add(&g_closed, 1);
                    else cc_atomic_fetch_add(&g_errors, 1);
                });
                n->spawn(() => [tx] {
                    cc_sleep_ms(1);
                    int v = 23;
                    int rc = cc_chan_send(tx.raw, &v, sizeof(int));
                    if (!(rc == 0 || rc == EPIPE)) cc_atomic_fetch_add(&g_errors, 1);
                });
                n->spawn(() => [tx] {
                    cc_sleep_ms(1);
                    tx.close();
                });
            }
            tx.close();
            cc_chan_free(ch);
        }

        if (cc_atomic_load(&g_errors) != 0) break;
    }

    if (cc_atomic_load(&g_errors) != 0) {
        fprintf(stderr, "FAIL: errors=%d data=%d closed=%d\n",
                cc_atomic_load(&g_errors),
                cc_atomic_load(&g_data),
                cc_atomic_load(&g_closed));
        return 1;
    }

    fprintf(stderr, "v2 lostwake outcomes: data=%d closed=%d\n",
            cc_atomic_load(&g_data), cc_atomic_load(&g_closed));
    return 0;
}
