// Smoke: !>(e) binder form on pointer; verifies CC_ERR_NULL synthesized and
// the generated message includes the call-site expression.
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static char* get_null_str(void) { return NULL; }

int main(void) {
    char* s = get_null_str() !>(e) {
        int is_null_kind = (e.kind == CC_ERR_NULL);
        int has_src = e.message != NULL && strstr(e.message, "get_null_str") != NULL;
        printf("is_null_kind=%d has_src=%d\n", is_null_kind, has_src);
        exit(0);
    };
    printf("UNEXPECTED s=%s\n", s);
    return 1;
}
