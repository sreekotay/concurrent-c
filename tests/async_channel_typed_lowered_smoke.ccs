#include <ccc/cc_runtime.cch>
#include <ccc/std/task.cch>
#include <assert.h>
#include <stdio.h>

@async int sender(CCChanTx tx) {
    int val = 42;
    intptr_t rc = await tx.send(val);
    printf("typed sender: sent %d, rc=%ld\n", val, (long)rc);
    return (int)rc;
}

@async int receiver(CCChanRx rx) {
    int val = 0;
    intptr_t rc = await rx.recv(&val);
    printf("typed receiver: received %d, rc=%ld\n", val, (long)rc);
    assert(rc == 0);
    return val;
}

int main(void) {
    int[~4 >] tx;
    int[~4 <] rx;
    cc_channel_pair(&tx, &rx);

    int send_rc = cc_block_on(int, sender(tx));
    int recv_val = cc_block_on(int, receiver(rx));

    assert(send_rc == 0);
    assert(recv_val == 42);

    chan_close(tx);
    chan_free(rx);

    printf("async_channel_typed_lowered_smoke: PASS\n");
    return 0;
}
