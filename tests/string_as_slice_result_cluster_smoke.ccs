#include <ccc/std/prelude.cch>
#include <assert.h>

static bool !>(CCError) accept_value(char[:] key, char[:] value) {
    (void)key;
    if (value.len == 0) return cc_err(CC_ERROR(CC_ERR_INVALID_ARG, "empty"));
    return cc_ok(true);
}

static int64_t !>(CCError) increment_and_store(char[:] key, int64_t value) {
    char buf[64];
    CCArena a = @create(buf, sizeof(buf)) @destroy;
    if (!a.base) return cc_err(CC_ERROR(CC_ERR_OUT_OF_MEMORY, "alloc"));

    CCString s = @string(value, &a);
    char[:0] v = s.as_slice();
    bool !>(CCError) set_res = accept_value(key, v);
    if (set_res.is_err()) return cc_err(set_res.error());
    return cc_ok(value);
}

int main(void) {
    int64_t !>(CCError) out = increment_and_store(cc_slice_from_cstr("k"), 41);
    assert(out.is_ok());
    assert(out.value() == 41);
    return 0;
}
