// Smoke: !> { ... } without trailing semicolon
#include <stdio.h>

static int g_ran;

bool !> (CCError) always_err_bool(void) {
    return cc_err(CC_ERR_NOT_FOUND, "always_err_bool");
}

int main(void) {
    for (int i = 0; i < 3; i++) {
        always_err_bool() !> { g_ran++; break; }
        g_ran += 100;
    }
    printf("ran=%d\n", g_ran);
    return 0;
}
