#include <ccc/cc_runtime.cch>
#include <ccc/cc_ufcs.cch>
#include <ccc/cc_type.cch>
#include <ccc/std/string.cch>
#include <assert.h>
#include <stdio.h>

int[~2 >] g_tx;
int[~2 <] g_rx;

@comptime {
    (void)cc_type_register("CCChanTx_*", (CCTypeHooks){
        .ufcs = (recv_type, method, mode, argv, arena) => {
        (void)recv_type;
        (void)mode;
        (void)argv;
        if (cc_slice_eq_cstr(method, "send")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_send");
        if (cc_slice_eq_cstr(method, "close")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_close");
        if (cc_slice_eq_cstr(method, "free")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_free");
        return cc_slice_empty();
    }});
    (void)cc_type_register("CCChanRx_*", (CCTypeHooks){
        .ufcs = (recv_type, method, mode, argv, arena) => {
        (void)recv_type;
        (void)argv;
        if (cc_slice_eq_cstr(method, "recv")) {
            return cc_slice_eq_cstr(mode, "await")
                ? cc_ufcs_emit_value_cstr(arena, "cc_channel_recv_task")
                : cc_ufcs_emit_value_cstr(arena, "cc_channel_recv");
        }
        if (cc_slice_eq_cstr(method, "close")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_close");
        if (cc_slice_eq_cstr(method, "free")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_free");
        return cc_slice_empty();
    }});
}

int main(void) {
    CCChan* ch = cc_channel_pair(&g_tx, &g_rx);
    int value = 0;
    assert(ch != NULL);

    (void)g_tx.send(7);
    (void)g_rx.recv(&value);
    assert(value == 7);

    g_tx.close();
    g_rx.free();

    printf("comptime_channel_ufcs_smoke: PASS\n");
    return 0;
}
