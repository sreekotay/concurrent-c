#include <ccc/cc_runtime.cch>
#include <ccc/cc_ufcs.cch>
#include <assert.h>
#include <stdio.h>

int[~2 >] g_tx;
int[~2 <] g_rx;

@comptime {
    (void)cc_ufcs_register("CCChanTx_*", (method, argv, arena) => {
        (void)argv;
        if (cc_ufcs_slice_eq_cstr(method, "send")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_send");
        if (cc_ufcs_slice_eq_cstr(method, "close")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_close");
        if (cc_ufcs_slice_eq_cstr(method, "free")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_free");
        return cc_slice_empty();
    });
    (void)cc_ufcs_register("CCChanRx_*", (method, argv, arena) => {
        (void)argv;
        if (cc_ufcs_slice_eq_cstr(method, "recv")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_recv");
        if (cc_ufcs_slice_eq_cstr(method, "close")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_close");
        if (cc_ufcs_slice_eq_cstr(method, "free")) return cc_ufcs_emit_value_cstr(arena, "cc_channel_free");
        return cc_slice_empty();
    });
}

int main(void) {
    CCChan* ch = cc_channel_pair(&g_tx, &g_rx);
    int value = 0;
    assert(ch != NULL);

    (void)g_tx.send(7);
    (void)g_rx.recv(&value);
    assert(value == 7);

    g_tx.close();
    g_rx.free();

    printf("comptime_channel_ufcs_smoke: PASS\n");
    return 0;
}
