#include <ccc/std/prelude.cch>
#include <ccc/std/exec.cch>

int main(void) {
    CCArena arena = cc_arena_heap(kilobytes(64));

    CCCommand cmd = cc_command(&arena, "ccc");
    cmd.arg("run");
    cmd.arg_if(false, "--timeout");
    cmd.arg_i32_if(true, 10);
    cmd.arg("tools/run_all.ccs");

    if (cmd.argc() != 4) {
        cc_arena_free(&arena);
        return 1;
    }
    if (strcmp(cmd.program(), "ccc") != 0) {
        cc_arena_free(&arena);
        return 2;
    }
    if (strcmp(cmd.get(1), "run") != 0) {
        cc_arena_free(&arena);
        return 3;
    }
    if (strcmp(cmd.get(2), "10") != 0) {
        cc_arena_free(&arena);
        return 4;
    }
    if (strcmp(cmd.get(3), "tools/run_all.ccs") != 0) {
        cc_arena_free(&arena);
        return 5;
    }

    const char** argv = cmd.argv();
    if (!argv) {
        cc_arena_free(&arena);
        return 6;
    }
    if (argv[4] != NULL) {
        cc_arena_free(&arena);
        return 7;
    }

    CCCommand echo = cc_command(&arena, "true");
    CCResult_int_CCIoError status;
    status = echo.status();
    if (cc_is_err(status)) {
        cc_arena_free(&arena);
        return 8;
    }
    if (cc_unwrap(status) != 0) {
        cc_arena_free(&arena);
        return 9;
    }

    cc_arena_free(&arena);
    return 0;
}
