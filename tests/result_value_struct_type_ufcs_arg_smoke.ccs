// Regression: `CCSlice !>(CCError) r = ...; entries.insert(r.value(), v);`
// used to lower `.value()` to an undeclared snake-cased helper
// `cc_result__c_c_slice__c_c_error_value(...)` because the `*` wildcard
// UFCS hook claimed ownership of `CCResult_*` types and the fallback
// scanner couldn't see the PascalCase `CCResult_T_E_value` form (it's
// macro-generated by CC_DECL_RESULT_SPEC and never appears literally in
// pre-expansion source).  The fix makes cc__emit_registered_callable
// defer to the family dispatcher for CCResult_* method lowerings.
#include <ccc/cc_runtime.cch>
#include <ccc/std/string.cch>
#include <ccc/std/map.cch>
#include <stdio.h>

typedef struct Entry { int id; } Entry;

static CCSlice !>(CCError) clone_key(CCArena* arena, char[:] src) {
    CCSlice cloned = cc_slice_clone(arena, src);
    if (src.len > 0 && (!cloned.ptr || cloned.len != src.len)) {
        return cc_err(CC_ERROR(CC_ERR_OUT_OF_MEMORY, "clone failed"));
    }
    return cc_ok(cloned);
}

static bool !>(CCError) insert_one(CCArena* arena,
                                   Map<char[:], Entry*> entries,
                                   char[:] key,
                                   Entry* e) {
    CCSlice !>(CCError) key_res = clone_key(arena, key);
    if (key_res.is_err()) return cc_err(key_res.error());
    if (entries.insert(key_res.value(), e) != 0) {
        return cc_err(CC_ERROR(CC_ERR_OUT_OF_MEMORY, "insert failed"));
    }
    return cc_ok(true);
}

int main(void) {
    CCArena arena = cc_arena_heap(1024);
    Map<char[:], Entry*> entries = map_new<char[:], Entry*>(&arena);
    Entry e = { .id = 1 };
    char[:] key = { .ptr = (char*)"hello", .len = 5 };

    bool !>(CCError) r = insert_one(&arena, entries, key, &e);
    if (r.is_err()) {
        fprintf(stderr, "err: %s\n", r.error().message);
        cc_arena_free(&arena);
        return 1;
    }
    printf("ok size=%zu\n", entries.len());
    cc_arena_free(&arena);
    return 0;
}
