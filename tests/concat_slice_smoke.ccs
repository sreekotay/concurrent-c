#include <ccc/std/prelude.cch>
#include <ccc/cc_ufcs.cch>
#include <ccc/cc_type.cch>
#include <ccc/std/string.cch>
#include <assert.h>
#include <stdio.h>
#include <string.h>

typedef struct {
    int value;
} NamedToy;

typedef struct {
    int value;
} LambdaToy;

static void named_toy_ping(NamedToy *toy) {
    toy->value += 1;
}

static void lambda_toy_ping(LambdaToy *toy) {
    toy->value += 10;
}

static CCSlice named_toy_ufcs_rewrite(CCSlice recv_type, CCSlice method, CCSlice mode, CCSliceArray argv, CCSliceArray arg_types, CCArena *arena) {
    (void)recv_type;
    (void)mode;
    (void)argv;
    (void)arg_types;
    return cc_ufcs_concat2(arena,
        cc_slice_from_buffer("named_toy_", sizeof("named_toy_") - 1),
        method);
}

@comptime {
    (void)cc_type_register("NamedToy", (CCTypeHooks){
        .ufcs = named_toy_ufcs_rewrite,
    });
    (void)cc_type_register("LambdaToy", (CCTypeHooks){
        .ufcs = (recv_type, method, mode, argv, arg_types, arena) => {
            (void)recv_type;
            (void)mode;
            (void)argv;
            (void)arg_types;
            return cc_ufcs_concat2(arena,
                cc_slice_from_buffer("lambda_toy_", sizeof("lambda_toy_") - 1),
                method);
        },
    });
}

int main(void) {
    {
        CCArena arena_storage = @create(kilobytes(4)) @destroy;
        if (!arena_storage.base) abort();
        CCArena* arena = &arena_storage;
        // Mixed inputs stay ergonomic: literals + CCString + literals.
        CCString suffix = CCString_new(arena);
        suffix.append("send");

        CCSlice channel_send = cc_concat(arena, "cc_channel_", &suffix, "_task");
        assert(channel_send.len == sizeof("cc_channel_send_task") - 1);
        assert(memcmp(channel_send.ptr, "cc_channel_send_task", channel_send.len) == 0);

        // Both handler forms now go through real comptime execution.
        NamedToy named = { 1 };
        LambdaToy lambda = { 2 };
        named.ping();
        lambda.ping();
        assert(named.value == 2);
        assert(lambda.value == 12);
    }

    printf("concat_slice_smoke: PASS\n");
    return 0;
}
