// Smoke: multi-line @errhandler body inlined at `!>;` must not shift
// line offsets of subsequent user source.
//
// Regression guard for [F11].  Before the fix, each bare `CALL !>;`
// splice site inlined the substituted handler body *verbatim* — so a
// 4-line @errhandler body pushed every byte below the splice down by
// 3 source lines.  TCC's AST byte offsets (built from the phase-1
// source) then no longer lined up with the rewritten phase-2 buffer,
// and the first downstream pass that trusts those offsets — async_ast's
// parameter-list scanner — walked past the real `(...)` header and
// picked up the first body statement as the parameter list, yielding
// `async_ast: failed to build statement list for @async function
// 'worker_fn' (no body block + no braces)`.
//
// Shape we pin: multi-line `@errhandler` + multiple bare `!>;` splice
// sites + an `@async` function defined *after* the sync caller, with
// real parameters that async_ast must resolve.  If the flattening
// helpers (`cc__pu_flatten_handler_body` in pass_result_unwrap.c and
// `cc__es_flatten_body` in pass_err_syntax.c) ever stop collapsing the
// inlined body, the build will fail here.

#include <ccc/std/prelude.cch>
#include <ccc/std/task.cch>
#include <stdio.h>

int !> (CCError) step(int x) {
    if (x < 0) return cc_err(CC_ERR_INVALID_ARG, "negative");
    return cc_ok(x + 1);
}

int !> (CCError) sync_caller(int a, int b, int c, int d) {
    // Multi-line body — each line below the splice point would shift
    // byte offsets absent the flattening helper.  Four inline sites
    // amplify the drift so that `worker_fn`'s header moves well outside
    // async_ast's cached span.
    @errhandler(CCError e) {
        int guard1 = 1;
        int guard2 = 2;
        (void)guard1;
        (void)guard2;
        return cc_err(e);
    }

    int ra = step(a) !>;
    int rb = step(b) !>;
    int rc = step(c) !>;
    int rd = step(d) !>;

    return cc_ok(ra + rb + rc + rd);
}

// Must appear AFTER sync_caller in the TU so the accumulated line
// drift hits async_ast's parameter scan for this function.
@async int worker_fn(int param_a, int param_b) {
    if (param_a < 0) return -1;
    if (param_b < 0) return -2;
    return param_a + param_b;
}

int main(void) {
    int !> (CCError) r = sync_caller(1, 2, 3, 4);
    if (cc_is_err(r)) { printf("sync_caller FAIL\n"); return 1; }
    // step(x) returns x+1, so 1+2+3+4 + 4 = 14.
    printf("sync=%d\n", cc_value(r));
    return 0;
}
