// Smoke: !> (expression position) RHS is `continue;` inside a loop
#include <stdio.h>

static int g_seen;

int !> (CCError) flip(int i) {
    return (i == 2) ? cc_err(CC_ERR_NOT_FOUND, "bad") : cc_ok(10);
}

int main(void) {
    int total = 0;
    for (int i = 0; i < 5; i++) {
        int v = flip(i) !> continue;
        total += v;
        g_seen++;
    }
    printf("total=%d seen=%d\n", total, g_seen);
    return 0;
}
