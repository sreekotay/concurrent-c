#include <ccc/cc_runtime.cch>
#include <ccc/std/task.cch>
#include <ccc/std/prelude.cch>

@async int noop(int v) { return v; }

@async int f(void) {
    int x = await noop(3);
    char buf[256];
    int out = 0;
    CCArena arena_storage = {0};
    if (cc_arena_init(&arena_storage, buf, sizeof(buf)) != 0) abort();
    if (1) {
        CCArena* arena = &arena_storage;
        int* slot = cc_arena_alloc_T(int, arena);
        if (!slot) abort();
        *slot = x;
        out = *slot;
    }
    cc_arena_free(&arena_storage);
    return out;
}

int main(void) {
    CCTaskIntptr t = f();
    intptr_t r = cc_block_on_intptr(t);
    return (r == 3) ? 0 : 1;
}
