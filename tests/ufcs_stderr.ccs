#include <ccc/std/prelude.cch>

int main(void) {
    {
        CCArena __cc_arena12 = @create(kilobytes(4)) @destroy;
        if (!__cc_arena12.base) abort();
        CCArena* ar = &__cc_arena12;
        CCString s = cc_string_new();
        s.append("stderr line1\n", ar);
        s.append("stderr line2\n", ar);
        cc_std_err.write("stderr literal\n");
        cc_std_err.write(s);
    
    }
    return 0;
}

