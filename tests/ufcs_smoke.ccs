#include <ccc/std/prelude.cch>

int main(void) {
    {
        CCArena __cc_arena11 = @create(kilobytes(8)) @destroy;
        if (!__cc_arena11.base) abort();
        CCArena* a = &__cc_arena11;
        CCString s = cc_string_new();
        s.append("UFCS smoke\n", a);

        CCString *sp = &s;
        sp->append("pointer receiver ok\n", a);

        // Nested UFCS: inner call rewritten inside outer call.
        cc_std_out_write_string(&s);
    
    }
    return 0;
}


