#include <ccc/cc_runtime.cch>
#include <ccc/cc_channel.cch>
#include <ccc/cc_nursery.cch>
#include <stdio.h>
#include <stdlib.h>

#include <ccc/cc_atomic.cch>

#define REQUESTS 10

typedef struct {
    int request_id;
} Req;

static cc_atomic_int g_errors = 0;

static void owner(CCChanRx req_rx, CCChanTx reply_tx) {
    Req* r = NULL;
    while (cc_io_avail(cc_channel_recv(req_rx, &r))) {
        if (!r) continue;
        int reply = 1000 + r->request_id;
        cc_channel_send(reply_tx, reply);
        free(r);
    }
}

static void client_loop(CCChanTx req_tx, CCChanRx reply_rx) {
    for (int i = 1; i <= REQUESTS; ++i) {
        Req* r = malloc(sizeof(Req));
        if (!r) {
            cc_atomic_fetch_add(&g_errors, 1);
            return;
        }
        r->request_id = i;

        if (!cc_io_avail(cc_channel_send(req_tx, r))) {
            cc_atomic_fetch_add(&g_errors, 1);
            free(r);
            break;
        }

        int reply = -1;
        if (!cc_io_avail(cc_channel_recv(reply_rx, &reply))) {
            cc_atomic_fetch_add(&g_errors, 1);
            break;
        }

        int expected = 1000 + i;
        if (reply != expected) {
            fprintf(stderr, "MISMATCH req=%d got=%d expected=%d\n", i, reply, expected);
            cc_atomic_fetch_add(&g_errors, 1);
            break;
        }
    }

    cc_channel_close(req_tx);
}

int main(void) {
    cc_atomic_store(&g_errors, 0);
    Req*[~32 N:1 >] req_tx;
    Req*[~32 N:1 <] req_rx;
    CCChan* rch = cc_channel_pair(&req_tx, &req_rx);
    if (!rch) return 1;

    int[~1 1:1 >] reply_tx;
    int[~1 1:1 <] reply_rx;
    CCChan* reply_ch = cc_channel_pair(&reply_tx, &reply_rx);
    if (!reply_ch) {
        cc_channel_free(rch);
        return 2;
    }

    CCNursery* n = cc_nursery_create();
    if (!n) {
        cc_channel_free(rch);
        cc_channel_free(reply_ch);
        return 3;
    }

    CCChanRx rx_raw = req_rx;
    CCChanTx reply_tx_raw = reply_tx;
    n.spawn(() => [rx_raw, reply_tx_raw] { owner(rx_raw, reply_tx_raw); });
    CCChanTx req_tx_raw = req_tx;
    CCChanRx reply_rx_raw = reply_rx;
    n.spawn(() => [req_tx_raw, reply_rx_raw] { client_loop(req_tx_raw, reply_rx_raw); });

    cc_nursery_wait(n);
    cc_channel_free(rch);
    cc_channel_free(reply_ch);
    cc_nursery_free(n);

    if (cc_atomic_load(&g_errors) != 0) return 4;
    printf("async_chan_minimal_smoke: PASS (%d requests)\n", REQUESTS);
    return 0;
}
