#include <ccc/cc_closure.cch>
#include <ccc/cc_nursery.cch>

int main(void) {
    int g = 0;
    int* gp = &g;
    int v = 5;

    CCClosure1 c = x => { int* p = (int*)x; if (p) *gp = *p; };

    {
        CCNursery* __cc_nursery85 = @create(NULL) @destroy;
        if (!__cc_nursery85) abort();

        (void)cc_nursery_spawn_closure1(__cc_nursery85, c, (intptr_t)&v);
    
    }
    return (g == 5) ? 0 : 1;
}

