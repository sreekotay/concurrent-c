#include <ccc/cc_runtime.cch>
#include <assert.h>
#include <stdio.h>

int main(void) {
    int[~3 >] tx;
    int[~3 <] rx;
    CCChan* ch = cc_channel_pair(&tx, &rx);

    int v = 0;
    (void)cc_channel_send(tx, 42);
    (void)cc_channel_recv(rx, &v);
    assert(v == 42);

    v = 0;
    (void)cc_channel_try_send(tx, 7);
    (void)cc_channel_try_recv(rx, &v);
    assert(v == 7);

    cc_channel_close(tx);
    cc_channel_free(rx);

    printf("channel_ops_typed_lowered_smoke: PASS\n");
    (void)ch;
    return 0;
}
