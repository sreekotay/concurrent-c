// Smoke: stack-backed slice is allowed to be captured by a nursery-scoped spawn closure (joined before frame exits).
#include <ccc/cc_slice.cch>
#include <ccc/cc_nursery.cch>
#include <stdlib.h>

int g = 0;

int main(void) {
    int* buf = malloc(sizeof(int) * 2);
    if (!buf) return 2;
    buf[0] = 7;
    buf[1] = 8;
    CCSlice s = cc_slice_from_parts(buf, 2, CC_SLICE_ID_UNTRACKED, 2);
    CCNursery* n = @create(NULL, () => {
        int *p = (int*)s.ptr;
        if (p && p[0] == 7) g = 1;
    }) @detach;
    if (!n) {
        free(buf);
        return 3;
    }
    (void)cc_nursery_wait(n);
    cc_nursery_free(n);
    free(buf);
    return (g == 1) ? 0 : 1;
}
